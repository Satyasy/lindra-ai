datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL") // role aplikasi (lindra_app) — tanpa hak UPDATE/DELETE audit_log
  directUrl  = env("DIRECT_DATABASE_URL") // superuser — hanya untuk migrasi
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Jantung sistem — narasi terstruktur + klasifikasi + status.
// Transkrip chat siswa disimpan sebagai rawTranscript Json (bukan tabel terpisah)
// supaya jumlah tabel tetap 9 sesuai rancangan.
model Report {
  id               String   @id @default(cuid())
  isAnonymous      Boolean  @default(true)
  identityData     Bytes? // blob AES-256-GCM, null kecuali "kirim dengan nama"
  rawTranscript    Json? // [{role, content, ts}]
  slots            Json? // status per-field terkunci + fase sesi (lib/ai/classify-narrative Slots)
  draft            Json? // draf terstruktur editable siswa (5 field + narasi), diisi saat compose
  narrative        String?
  urgencyLevel     String? // rendah | sedang | tinggi | kritis
  perpetratorRole  String? // siswa | guru-staf | orangtua-wali
  locationCategory String? // dalam-sekolah | lintas-sekolah
  violenceType     String[]
  actionSignals    Json? // {cederaFisik, sudahBerulang, relasiKuasaTimpang, adaBukti, adaBahayaLangsung} — input rule-engine rekomendasi aksi (lib/ai/recommend-action)
  urgentVisum      Boolean  @default(false)
  status           String   @default("draft") // draft -> terkirim -> ditinjau -> selesai
  contentHash      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Penanganan BK (antrean tabel) — assign & status SELALU manual, tak ada aksi
  // otomatis atas skor urgensi AI (mitigasi automation-bias).
  assignedToId   String?
  assignedTo     StaffAccount? @relation(fields: [assignedToId], references: [id])
  handlingStatus String  @default("belum-diassign") // belum-diassign | dijadwalkan | investigasi | eskalasi-hukum | selesai

  referralCode ReferralCode?
  routingLogs  RoutingLog[]
  followups    Followup[]
  auditLogs    AuditLog[]
  chatThreads  ChatThread[]
  evidences    Evidence[]
}

// Bukti terlampir siswa (foto/PDF). Byte disimpan di tabel terpisah — bukan di
// Report.rawTranscript — supaya read panas Report (tiap giliran chat) tetap ringan.
// ponytail: blob di kolom Bytes Postgres, pindah ke object storage kalau volume besar.
model Evidence {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id])
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
}

model RoutingLog {
  id          String    @id @default(cuid())
  reportId    String
  report      Report    @relation(fields: [reportId], references: [id])
  destination String // dashboard-bk | satgas-eksternal | sapa129 | eskalasi-darurat
  hashAtSend  String
  openedAt    DateTime?
  createdAt   DateTime  @default(now())
}

// Kode yang dipegang siswa untuk cek status tanpa membuka identitas
model ReferralCode {
  id        String   @id @default(cuid())
  code      String   @unique
  reportId  String   @unique
  report    Report   @relation(fields: [reportId], references: [id])
  createdAt DateTime @default(now())
}

// Ada untuk desain SLA/follow-up ke depan — scheduler-nya di luar scope sprint 24 jam
model Followup {
  id          String    @id @default(cuid())
  reportId    String
  report      Report    @relation(fields: [reportId], references: [id])
  scheduledAt DateTime
  slaStatus   String    @default("pending") // pending | on-track | breached | done
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  // Follow-up proaktif (opt-in siswa). contactEmail = ciphertext base64 (identity-crypto),
  // BUKAN plaintext. escalated = penanda auto-escalate SAPA 129 sekali-jalan.
  contactEmail     String?
  proactiveEnabled Boolean   @default(false)
  noProgressCount  Int       @default(0) // dinaikkan CRON saat kasus ter-flag tapi admin diam (bukan oleh user)
  lastCheckinAt    DateTime?
  escalated        Boolean   @default(false)

  // W5 sesi follow-up (KABAR → CEK_KASUS). state = fase sesi aktif; transisi deterministik
  // (business logic, bukan AI). followUpFlaggedAt = di-set saat user jawab "Iya" (masih perlu
  // ditindaklanjuti) — timestamp agar bisa diurutkan di antrean BK; TIDAK menyentuh noProgressCount.
  state             String    @default("kabar") // kabar | cek_kasus | flagged | closed | crisis_override
  followUpFlaggedAt DateTime?
}

// Append-only, ditegakkan lewat REVOKE UPDATE/DELETE di level database (lihat migration)
model AuditLog {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id])
  actor     String // staff id atau 'system'
  action    String // created | sent | opened | status-changed
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("audit_log")
}

model StaffAccount {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String // format scrypt "salt:hash"
  role         String // bk | satgas — sengaja hanya 2, bukan RBAC penuh
  createdAt    DateTime     @default(now())
  chatThreads  ChatThread[]
  assignedReports Report[]
}

// ChatThread/ChatMessage untuk pendampingan asinkron BK (UI di luar scope 24 jam)
model ChatThread {
  id        String        @id @default(cuid())
  reportId  String?
  report    Report?       @relation(fields: [reportId], references: [id])
  staffId   String?
  staff     StaffAccount? @relation(fields: [staffId], references: [id])
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id])
  sender    String // student | staff
  content   String
  createdAt DateTime   @default(now())
}

// Potongan dokumen tata tertib + embedding untuk pipeline RAG.
// Dimensi vector harus sinkron dengan EMBEDDING_DIMENSION di lib/config.ts.
model SchoolPolicyChunk {
  id            String                       @id @default(cuid())
  documentTitle String
  content       String
  embedding     Unsupported("vector(1536)")?
  createdAt     DateTime                     @default(now())
}
