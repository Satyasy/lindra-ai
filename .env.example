# Role aplikasi � TANPA hak UPDATE/DELETE pada audit_log (chain of custody)
DATABASE_URL="postgresql://lindra_app:lindra_app_dev@localhost:5432/lindra_dev"
# Superuser � hanya dipakai prisma migrate
DIRECT_DATABASE_URL="postgresql://lindra:lindra_dev@localhost:5432/lindra_dev"

# Pembagian 3 key Groq — lihat Bagian IV.4.2 dokumen panduan
GROQ_API_KEY_STUDENT=""   # Key 1 — percakapan utama siswa
GROQ_API_KEY_BK=""        # Key 2 — Tier 2 klasifikasi + RAG
GROQ_API_KEY_BACKUP=""    # Key 3 — failover otomatis saat 429

EMBEDDING_API_KEY=""

NEXTAUTH_SECRET=""        # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Kunci AES-256-GCM untuk Report.identityData (32 byte hex)
# openssl rand -hex 32
IDENTITY_ENCRYPTION_KEY=""

SLA_THRESHOLD_HOURS=48

# Aktifkan section pasal UU di narasi rekomendasi kasus (baris SchoolPolicyChunk berawalan 'UU ')
UU_RETRIEVAL_ENABLED=false

# --- Follow-up proaktif (W5) ---
# Ambang siklus kemandekan admin sebelum sesi follow-up menawarkan SAPA 129 ke user
SAPA129_THRESHOLD=2
# true = email check-in pertama dikirim segera saat opt-in (bypass ambang; demo/testing)
DUMMY_FOLLOWUP_IMMEDIATE=false

# Email follow-up (Resend). Tanpa RESEND_API_KEY → email di-skip (bukan error), cron tetap jalan.
RESEND_API_KEY=""
FOLLOWUP_EMAIL_FROM="Catatan Harian <halo@catatan-harian.app>"
APP_URL="http://localhost:3000"
# Auth cron non-Vercel: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""
